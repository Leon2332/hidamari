#, python-brace-format
msgid "Set For {monitor}"
msgstr "{monitor} に設定"

#. add all option
#: src/hidamari/gui/control.py:125
msgid "Set For All"
msgstr "すべてに設定"

#: src/hidamari/gui/control.py:213
msgid "Couldn't connect to server"
msgstr "サーバーに接続できませんでした"

#: src/hidamari/gui/control.py:226
msgid "Welcome to Hidamari 🤗"
msgstr "Hidamari へようこそ 🤗"

#: src/hidamari/gui/control.py:230
msgid ""
"Quickstart for adding local videos:\n"
" ・Click the folder icon to open the Hidamari folder\n"
" ・Put your videos there\n"
" ・Click the refresh button"
msgstr ""
"ローカル動画を追加するクイックスタート:\n"
" ・フォルダーアイコンをクリックして Hidamari フォルダーを開きます\n"
" ・動画をそこに入れます\n"
" ・更新ボタンをクリックします"

#: src/hidamari/gui/control.py:246
msgid "Oops!"
msgstr "おっと！"

#: src/hidamari/gui/control.py:265
msgid "No Video Selected"
msgstr "動画が選択されていません"

#: src/hidamari/gui/control.py:267
msgid ""
"There are no video selected.\n"
"Please choose one first."
msgstr ""
"動画が選択されていません。\n"
"まず動画を1つ選択してください。"

#: src/hidamari/gui/control.py:300
msgid "Please choose a HTML file"
msgstr "HTML ファイルを選択してください"

#: src/hidamari/gui/control.py:423
#, python-brace-format
msgid ""
"Failed to access {url}. Error:\n"
"{error}"
msgstr ""
"{url} にアクセスできませんでした。エラー:\n"
"{error}"

#: src/hidamari/gui/control.py:428
#, python-brace-format
msgid "Failed to access {url}. Error code: {code}"
msgstr "{url} にアクセスできませんでした。エラーコード: {code}"

#: src/hidamari/gui/control.py:444
#, python-brace-format
msgid ""
"Failed to stream {url}. Error:\n"
"{error}"
msgstr ""
"{url} のストリーミングに失敗しました。エラー:\n"
"{error}"

